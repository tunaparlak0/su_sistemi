generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscription {
  id             String    @id // idGenerator ile kendin vereceksin (örn: sub_xxxx)
  status         String    @default("NULL") // NULL, PENDING , ACTIVE
  startDate      DateTime?  @default(now())
  meterId        String?
  meter          Meter?     @relation(fields: [meterId], references: [meterNo])
  owners         User[]    
  invoices       Invoice[]
  logs           SubscriptionLog[]
}

model User {
  id             String        @id @default(uuid())
  idNo           String?       
  taxNo          String?
  name           String
  surname        String
  telephone      String?       
  mail           String        
  
  // User bir aboneliğe bağlı olabilir, ama zorunlu değil.
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId String?       @unique  
  worker         Worker?
  logs           SubscriptionLog[]
}

model Invoice {
  id             String       @id @default(uuid())
  totalPrice     Decimal
  usedWater      Decimal
  unitPrice      Decimal
  taxRate        Decimal
  invoiceDate    DateTime     @default(now())
  isPaid         Boolean      @default(false) // Ödendi mi? (True / False)
  dueDate        DateTime
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  subscriptionId String
}
model Worker {
  id        String   @unique
  role      String   @default("WORKER") // WORKER veya ADMIN
  status    String   @default("ACTIVE")
  token     String
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
}

model SubscriptionLog {
  id             String       @id @default(uuid())
  meterNo        String       
  action         String       // "TRANSFER", "NEW_START", "CANCELLED"
  changedAt      DateTime     @default(now())
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])  
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  meterId        String?
  meter          Meter?        @relation(fields: [meterId], references: [meterNo], onDelete: SetNull)
}
model Meter {
  meterNo        String            @id  //abone nosu gibi bir şey olucak
  address        String
  subscriptions  Subscription[]    
  logs           SubscriptionLog[]
}
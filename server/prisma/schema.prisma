generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscription {
  id          String       @id @default(uuid())
  idNo        String?
  taxNo       String?
  address     String
  status      String    @default("PENDING")
  startDate   DateTime  @default(now())
  dueDate     DateTime
  // Aboneliğin sahiplerini User tablosundaki relation üzerinden göreceğiz
  owners      User[]    
  invoices    Invoice[]
  logs        SubscriptionLog[]
}

model User {
  id             String        @id @default(uuid())
  role           String        @default("USER")
  name           String
  surname        String
  telephone      String?       @unique
  token          String?       @unique
  mail           String        @unique
  
  // User bir aboneliğe bağlı olabilir, ama zorunlu değil.
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId String?
  worker         Worker?
}

model Invoice {
  id             String       @id @default(uuid())
  totalPrice     Decimal
  usedWater      Decimal
  unitPrice      Decimal
  taxRate        Decimal
  invoiceDate    DateTime     @default(now())
  status         String       @default("UNPAID")

  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  subscriptionId String
}
model Worker {
  id        String   @id @default(uuid())
  role      String   @default("WORKER") // WORKER veya ADMIN
  status    String   @default("ACTIVE")

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

}

model SubscriptionLog {
  id          String   @id @default(uuid())
  meterNo     String   
  oldOwnerId  String?  // Eski abone ID
  newOwnerId  String?  // Yeni abone ID
  action      String   // "TRANSFER", "NEW_START", "CANCELLED"
  changedAt   DateTime @default(now())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

}
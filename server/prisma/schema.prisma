generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscription {
  id             String    @id // idGenerator ile kendin vereceksin (örn: sub_xxxx)
  idNo           String?
  taxNo          String?
  status         String    @default("PENDING")
  startDate      DateTime  @default(now())
  dueDate        DateTime
  // Hangi sayaçla ilişkili?
  meterId        String
  meter          Meter     @relation(fields: [meterId], references: [id])
  owners         User[]    
  invoices       Invoice[]
  logs           SubscriptionLog[]
}

model User {
  id             String        @id @default(uuid())
  idNo           String        @unique
  name           String
  surname        String
  telephone      String?       
  mail           String        
  
  // User bir aboneliğe bağlı olabilir, ama zorunlu değil.
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId String?
  worker         Worker?
  logs           SubscriptionLog[]
}

model Invoice {
  id             String       @id @default(uuid())
  totalPrice     Decimal
  usedWater      Decimal
  unitPrice      Decimal
  taxRate        Decimal
  invoiceDate    DateTime     @default(now())
  isPaid         Boolean      @default(false) // Ödendi mi? (True / False)
  dueDate        DateTime
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  subscriptionId String
}
model Worker {
  id        String   @unique
  role      String   @default("WORKER") // WORKER veya ADMIN
  status    String   @default("ACTIVE")
  token     String
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
}

model SubscriptionLog {
  id             String       @id @default(uuid())
  meterNo        String       
  action         String       // "TRANSFER", "NEW_START", "CANCELLED"
  changedAt      DateTime     @default(now())
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])  
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  meterId        String?
  meter          Meter?        @relation(fields: [meterId], references: [id], onDelete: SetNull)
}
model Meter {
  id             String            @id  // idGenerator ile autoincrement yapıcaz abone nosu gibi bir şey olucak
  meterNo        String            @unique // SK-000001 gibi sayaç numarası
  address        String
  subscriptions  Subscription[]    
  logs           SubscriptionLog[]
}